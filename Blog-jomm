<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bits, Bytes y Planeta — Blog Educativo de Tecnología</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&family=Playfair+Display:wght@600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #006400;
    --green-light: #007a00;
    --green-glow: rgba(0,100,0,0.15);
    --blue: #0077B6;
    --blue-light: #0096e0;
    --blue-glow: rgba(0,119,182,0.15);
    --bg: #f7f8fa;
    --bg-alt: #ffffff;
    --text: #1a1a2e;
    --text-light: #4a4a6a;
    --text-muted: #8a8aaa;
    --border: #e2e4e8;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
    --shadow-md: 0 4px 20px rgba(0,0,0,0.08);
    --shadow-lg: 0 12px 40px rgba(0,0,0,0.12);
    --radius: 14px;
    --radius-lg: 22px;
  }
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg); color: var(--text);
    line-height: 1.7; -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* ══════════ NAV ══════════ */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(20px) saturate(1.8);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: all 0.3s;
  }
  .nav.scrolled { box-shadow: 0 2px 24px rgba(0,0,0,0.08); }
  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; height: 64px;
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-weight: 800; font-size: 1.15rem;
    background: linear-gradient(135deg, var(--green), var(--blue));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    cursor: pointer; white-space: nowrap;
    position: relative;
  }
  .nav-logo::after {
    content: ''; position: absolute; bottom: -2px; left: 0;
    width: 100%; height: 2px; border-radius: 2px;
    background: linear-gradient(90deg, var(--green), var(--blue));
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s;
  }
  .nav-logo:hover::after { transform: scaleX(1); }
  .nav-links { display: flex; gap: 2px; list-style: none; }
  .nav-links a {
    text-decoration: none; color: var(--text-light);
    font-size: 0.84rem; font-weight: 500;
    padding: 8px 14px; border-radius: 10px;
    transition: all 0.25s; position: relative;
  }
  .nav-links a:hover { color: var(--green); background: rgba(0,100,0,0.06); }
  .nav-links a.active {
    color: #fff; background: linear-gradient(135deg, var(--green), var(--blue));
    box-shadow: 0 2px 12px rgba(0,100,0,0.25);
  }
  .hamburger {
    display: none; background: none; border: none; cursor: pointer;
    width: 40px; height: 40px; position: relative;
    border-radius: 10px; transition: background 0.2s;
  }
  .hamburger:hover { background: rgba(0,0,0,0.04); }
  .hamburger span {
    display: block; width: 20px; height: 2px;
    background: var(--text); border-radius: 2px;
    position: absolute; left: 10px; transition: all 0.3s;
  }
  .hamburger span:nth-child(1) { top: 12px; }
  .hamburger span:nth-child(2) { top: 19px; }
  .hamburger span:nth-child(3) { top: 26px; }
  .hamburger.open span:nth-child(1) { transform: rotate(45deg); top: 19px; }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg); top: 19px; }

  @media (max-width: 900px) {
    .hamburger { display: block; }
    .nav-links {
      display: none; flex-direction: column;
      position: absolute; top: 64px; left: 0; right: 0;
      background: rgba(255,255,255,0.98);
      backdrop-filter: blur(20px);
      padding: 12px 16px; gap: 4px;
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-md);
    }
    .nav-links.open { display: flex; }
    .nav-links a { padding: 14px 18px; font-size: 0.95rem; border-radius: 12px; }
  }

  /* ══════════ PAGES ══════════ */
  .page { display: none; min-height: 100vh; padding-top: 64px; }
  .page.active { display: block; animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ══════════ HERO HOME ══════════ */
  .hero {
    position: relative; overflow: hidden;
    background: linear-gradient(160deg, #003300 0%, var(--green) 30%, #004d40 60%, var(--blue) 100%);
    padding: 100px 24px 80px; text-align: center; color: #fff;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 600px 400px at 20% 50%, rgba(0,200,100,0.12), transparent),
      radial-gradient(ellipse 500px 500px at 80% 30%, rgba(0,119,182,0.15), transparent);
  }
  .hero::after {
    content: ''; position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='80' height='80' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='40' cy='40' r='1.5' fill='rgba(255,255,255,0.08)'/%3E%3C/svg%3E");
  }
  .hero-orb {
    position: absolute; border-radius: 50%;
    filter: blur(60px); opacity: 0.3;
    animation: float 8s ease-in-out infinite;
  }
  .hero-orb.orb1 {
    width: 300px; height: 300px; background: #00c853;
    top: -80px; left: -60px; animation-delay: 0s;
  }
  .hero-orb.orb2 {
    width: 250px; height: 250px; background: var(--blue);
    bottom: -60px; right: -40px; animation-delay: -3s;
  }
  .hero-orb.orb3 {
    width: 180px; height: 180px; background: #00bcd4;
    top: 40%; left: 60%; animation-delay: -5s;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.05); }
  }
  .hero-content { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    padding: 8px 20px; border-radius: 100px;
    font-size: 0.76rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 2px;
    margin-bottom: 24px;
    backdrop-filter: blur(10px);
  }
  .hero-badge .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #00e676; animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    font-weight: 800; line-height: 1.15; margin-bottom: 12px;
    text-shadow: 0 2px 40px rgba(0,0,0,0.3);
  }
  .hero h1 .accent {
    background: linear-gradient(90deg, #69f0ae, #40c4ff);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero .subtitle {
    font-size: 1.1rem; font-weight: 500; color: rgba(255,255,255,0.7);
    margin-bottom: 20px; letter-spacing: 0.3px;
  }
  .hero p {
    font-size: 1rem; line-height: 1.8;
    color: rgba(255,255,255,0.8); max-width: 640px; margin: 0 auto;
  }
  .hero-divider {
    width: 60px; height: 3px; margin: 24px auto 20px;
    background: linear-gradient(90deg, #69f0ae, #40c4ff);
    border-radius: 3px;
  }

  /* ══════════ CARDS ══════════ */
  .cards-section {
    max-width: 1200px; margin: 0 auto; padding: 72px 24px;
    position: relative;
  }
  .cards-section::before {
    content: ''; position: absolute;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, var(--green-glow), transparent 70%);
    top: -100px; left: -200px; pointer-events: none;
  }
  .cards-section::after {
    content: ''; position: absolute;
    width: 350px; height: 350px; border-radius: 50%;
    background: radial-gradient(circle, var(--blue-glow), transparent 70%);
    bottom: -80px; right: -150px; pointer-events: none;
  }
  .section-header { text-align: center; margin-bottom: 52px; position: relative; z-index: 1; }
  .section-label {
    font-size: 0.73rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 3px;
    color: var(--blue); margin-bottom: 10px;
    display: flex; align-items: center; justify-content: center; gap: 12px;
  }
  .section-label::before, .section-label::after {
    content: ''; width: 40px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue));
  }
  .section-label::after { background: linear-gradient(90deg, var(--blue), transparent); }
  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.1rem; font-weight: 700;
  }
  .cards-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
    gap: 32px; position: relative; z-index: 1;
  }
  .card {
    background: var(--bg-alt); border-radius: var(--radius-lg);
    overflow: hidden; cursor: pointer; border: 1px solid var(--border);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); position: relative;
  }
  .card::before {
    content: ''; position: absolute; inset: 0;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--green-glow), var(--blue-glow));
    opacity: 0; transition: opacity 0.4s; z-index: 0;
  }
  .card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); border-color: transparent; }
  .card:hover::before { opacity: 1; }
  .card-img-wrap { overflow: hidden; position: relative; z-index: 1; }
  .card-img {
    width: 100%; height: 230px; object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .card:hover .card-img { transform: scale(1.06); }
  .card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%);
    pointer-events: none;
  }
  .card-tag {
    position: absolute; top: 16px; left: 16px;
    padding: 5px 14px; border-radius: 8px;
    font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1.2px; color: #fff;
    backdrop-filter: blur(8px); z-index: 2;
  }
  .card-tag.green { background: rgba(0,100,0,0.85); }
  .card-tag.blue { background: rgba(0,119,182,0.85); }
  .card-tag.teal { background: rgba(0,121,107,0.85); }
  .card-body { padding: 26px; position: relative; z-index: 1; background: var(--bg-alt); }
  .card-body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem; font-weight: 700; margin-bottom: 4px;
  }
  .card-body .card-subtitle { font-size: 0.82rem; font-weight: 600; color: var(--blue); margin-bottom: 12px; }
  .card-body p { font-size: 0.9rem; color: var(--text-light); line-height: 1.65; }
  .card-arrow {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 18px; font-size: 0.84rem; font-weight: 700;
    color: var(--green); transition: all 0.3s;
  }
  .card-arrow .arrow-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--green-glow); transition: all 0.3s; font-size: 0.85rem;
  }
  .card:hover .card-arrow .arrow-icon { background: var(--green); color: #fff; transform: translateX(4px); }

  /* ══════════ SUBPAGE HERO ══════════ */
  .subpage-hero {
    position: relative; overflow: hidden;
    padding: 72px 24px 56px; text-align: center; color: #fff;
  }
  .subpage-hero::before {
    content: ''; position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='30' cy='30' r='1' fill='rgba(255,255,255,0.06)'/%3E%3C/svg%3E");
  }
  .subpage-hero::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 80px;
    background: linear-gradient(to top, var(--bg), transparent);
  }
  .subpage-hero.green-bg { background: linear-gradient(160deg, #002200, var(--green), #004d40); }
  .subpage-hero.blue-bg { background: linear-gradient(160deg, #002244, var(--blue), #004d6d); }
  .subpage-hero.teal-bg { background: linear-gradient(160deg, #002020, #00796b, #004d40); }
  .subpage-hero.purple-bg { background: linear-gradient(160deg, #1a0033, #6a1b9a, #4a148c); }
  .subpage-hero .hero-content { position: relative; z-index: 2; }
  .subpage-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4.5vw, 2.8rem);
    font-weight: 800; margin-bottom: 12px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }
  .subpage-hero p { font-size: 1rem; color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto; }
  .breadcrumb {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.78rem; color: rgba(255,255,255,0.5); margin-bottom: 16px;
  }
  .breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; cursor: pointer; }
  .breadcrumb a:hover { color: #fff; }

  /* ══════════ CONTENT ══════════ */
  .content-wrap { max-width: 820px; margin: 0 auto; padding: 48px 24px 80px; position: relative; }
  .content-wrap h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem; font-weight: 700; color: var(--green);
    margin: 48px 0 16px; padding-bottom: 10px; position: relative;
  }
  .content-wrap h2::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 50px; height: 3px; border-radius: 3px;
    background: linear-gradient(90deg, var(--green), var(--blue));
  }
  .content-wrap h3 { font-size: 1.12rem; font-weight: 700; margin: 28px 0 10px; }
  .content-wrap p { font-size: 0.95rem; color: var(--text-light); margin-bottom: 16px; line-height: 1.78; }
  .content-wrap ul, .content-wrap ol { padding-left: 24px; margin-bottom: 16px; }
  .content-wrap li { font-size: 0.95rem; color: var(--text-light); margin-bottom: 8px; line-height: 1.68; }
  .content-wrap strong { color: var(--text); }

  /* ══════════ IMAGE BLOCKS ══════════ */
  .img-block {
    margin: 36px 0; border-radius: var(--radius-lg);
    overflow: hidden; border: 1px solid var(--border);
    box-shadow: var(--shadow-md); transition: all 0.3s;
  }
  .img-block:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }
  .img-block img { width: 100%; height: 320px; object-fit: cover; display: block; }
  .img-caption {
    padding: 14px 18px; font-size: 0.82rem; color: var(--text-muted);
    background: var(--bg-alt); border-top: 1px solid var(--border);
    display: flex; align-items: flex-start; gap: 10px;
  }
  .img-caption .caption-icon {
    width: 20px; height: 20px; border-radius: 4px;
    background: var(--green-glow); display: flex; align-items: center;
    justify-content: center; font-size: 0.7rem; flex-shrink: 0; margin-top: 1px;
  }
  .img-caption .unsplash-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; color: var(--blue);
    display: block; margin-top: 4px;
    padding: 3px 8px; background: rgba(0,119,182,0.06);
    border-radius: 4px; width: fit-content;
  }

  /* ══════════ CALLOUT ══════════ */
  .callout {
    background: linear-gradient(135deg, rgba(0,100,0,0.04), rgba(0,119,182,0.04));
    border-left: 4px solid; border-image: linear-gradient(to bottom, var(--green), var(--blue)) 1;
    padding: 22px 26px; border-radius: 0 var(--radius) var(--radius) 0;
    margin: 28px 0; position: relative;
  }
  .callout p { margin: 0; font-size: 0.92rem; }
  .callout strong { color: var(--green); }

  /* ══════════ STAT GRID ══════════ */
  .stat-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px; margin: 32px 0;
  }
  .stat-card {
    background: var(--bg-alt); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 24px 16px; text-align: center;
    transition: all 0.3s; position: relative; overflow: hidden;
  }
  .stat-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--green), var(--blue));
  }
  .stat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .stat-card .number {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem; font-weight: 800; color: var(--green);
  }
  .stat-card .label { font-size: 0.78rem; color: var(--text-muted); margin-top: 6px; line-height: 1.4; }

  /* ══════════ TIMELINE ══════════ */
  .timeline { position: relative; padding-left: 36px; margin: 32px 0; }
  .timeline::before {
    content: ''; position: absolute; left: 10px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--green), var(--blue), var(--green));
    border-radius: 2px;
  }
  .timeline-item {
    position: relative; margin-bottom: 32px;
    padding: 20px 24px; background: var(--bg-alt);
    border: 1px solid var(--border); border-radius: var(--radius);
    transition: all 0.3s;
  }
  .timeline-item:hover { box-shadow: var(--shadow-md); transform: translateX(4px); }
  .timeline-item::before {
    content: ''; position: absolute; left: -32px; top: 24px;
    width: 14px; height: 14px; border-radius: 50%;
    background: linear-gradient(135deg, var(--green), var(--blue));
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 3px var(--green-glow);
  }
  .timeline-item .era {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.76rem; font-weight: 600; color: var(--blue); margin-bottom: 6px;
    padding: 2px 10px; background: var(--blue-glow); border-radius: 6px; display: inline-block;
  }
  .timeline-item h4 { font-size: 1.08rem; font-weight: 700; margin-bottom: 8px; }
  .timeline-item p { font-size: 0.9rem; margin: 0; color: var(--text-light); }

  /* ══════════ DEVICE TABLE ══════════ */
  .table-wrap {
    border-radius: var(--radius-lg); overflow: hidden;
    border: 1px solid var(--border); box-shadow: var(--shadow-sm); margin: 24px 0;
  }
  .device-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
  .device-table th {
    background: linear-gradient(135deg, var(--green), var(--blue));
    color: #fff; padding: 14px 18px; text-align: left; font-weight: 600;
  }
  .device-table td { padding: 13px 18px; border-bottom: 1px solid var(--border); }
  .device-table tr:last-child td { border-bottom: none; }
  .device-table tr:hover { background: rgba(0,119,182,0.03); }
  .device-type {
    display: inline-block; padding: 3px 12px;
    border-radius: 100px; font-size: 0.73rem; font-weight: 700;
  }
  .device-type.entrada { background: #e8f5e9; color: var(--green); }
  .device-type.salida { background: #e3f2fd; color: var(--blue); }
  .device-type.mixto { background: #fff3e0; color: #e65100; }

  /* ══════════ EXCEL EXERCISES ══════════ */
  .exercise-card {
    background: var(--bg-alt); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 28px 32px; margin: 28px 0;
    position: relative; overflow: hidden; transition: all 0.3s;
  }
  .exercise-card:hover { box-shadow: var(--shadow-md); }
  .exercise-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--green), var(--blue));
  }
  .exercise-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem; font-weight: 700; color: var(--blue);
    text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px;
    display: inline-block; padding: 3px 10px;
    background: var(--blue-glow); border-radius: 6px;
  }
  .exercise-card h4 { font-size: 1.08rem; font-weight: 700; margin-bottom: 8px; }
  .exercise-card > p { font-size: 0.92rem; color: var(--text-light); margin-bottom: 10px; }
  .formula-tag {
    display: inline-block; margin: 4px 4px 4px 0;
    padding: 7px 16px; border-radius: 8px;
    background: rgba(0,119,182,0.06); border: 1px solid rgba(0,119,182,0.12);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem; color: var(--blue); font-weight: 500;
  }
  .excel-preview {
    border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--border); margin: 16px 0;
  }
  .excel-preview table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .excel-preview th {
    background: var(--green); color: #fff;
    padding: 8px 14px; text-align: center; font-weight: 600; font-size: 0.76rem;
  }
  .excel-preview td { padding: 9px 14px; border: 1px solid var(--border); text-align: center; }
  .excel-preview tr:nth-child(even) { background: rgba(0,100,0,0.02); }
